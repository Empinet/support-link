{
    "name": "empinet/support-link",
    "description": "Generate and validate signed support links for Empinet products.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Empinet\\SupportLink\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Empinet\\SupportLink\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
